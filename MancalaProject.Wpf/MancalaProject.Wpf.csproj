<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\MancalaProject.Core\MancalaProject.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Emit an XML documentation file and warn (CS1591) on any public member
         that lacks an XML doc comment. Mirrors the Core / Console projects so
         documentation enforcement is consistent across the whole solution.
         WPF's auto-generated *.g.cs files carry an <auto-generated> header,
         which Roslyn already exempts from CS1591 — so only hand-written code
         is checked. -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

</Project>

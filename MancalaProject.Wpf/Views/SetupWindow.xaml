<Window x:Class="MancalaProject.Wpf.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mancala — Setup"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5EFE0"
        FontFamily="Segoe UI">

    <Grid Margin="35,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Mancala"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="#3E2A1F"
                   Margin="0,0,0,24"/>

        <!-- Mode -->
        <GroupBox Grid.Row="1"
                  Header="Game Mode"
                  Foreground="#3E2A1F"
                  FontSize="15"
                  FontWeight="SemiBold"
                  Padding="8"
                  Margin="0,0,0,18">
            <StackPanel Margin="6,8">
                <RadioButton Content="Player vs Computer"
                             GroupName="Mode"
                             IsChecked="{Binding IsVsComputer}"
                             FontSize="16"
                             FontWeight="Normal"
                             Margin="0,6"/>
                <RadioButton Content="Player vs Player"
                             GroupName="Mode"
                             IsChecked="{Binding IsVsPlayer}"
                             FontSize="16"
                             FontWeight="Normal"
                             Margin="0,6"/>
            </StackPanel>
        </GroupBox>

        <!-- Difficulty -->
        <GroupBox Grid.Row="2"
                  Header="Difficulty"
                  Foreground="#3E2A1F"
                  FontSize="15"
                  FontWeight="SemiBold"
                  Padding="8"
                  IsEnabled="{Binding IsDifficultyEnabled}">
            <StackPanel Margin="6,8">
                <RadioButton Content="Easy"
                             GroupName="Difficulty"
                             IsChecked="{Binding IsEasy}"
                             FontSize="16"
                             FontWeight="Normal"
                             Margin="0,5"/>
                <RadioButton Content="Medium"
                             GroupName="Difficulty"
                             IsChecked="{Binding IsMedium}"
                             FontSize="16"
                             FontWeight="Normal"
                             Margin="0,5"/>
                <RadioButton Content="Hard"
                             GroupName="Difficulty"
                             IsChecked="{Binding IsHard}"
                             FontSize="16"
                             FontWeight="Normal"
                             Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Buttons row -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Height="38"
                    FontSize="14"
                    Margin="0,0,12,0"
                    IsCancel="True"/>
            <Button Content="Start"
                    Width="100"
                    Height="38"
                    FontSize="14"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    Click="OnStartClick"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MancalaProject.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MancalaProject.Wpf"
        mc:Ignorable="d"
        Title="Mancala"
        Height="520" Width="960"
        MinHeight="480" MinWidth="900"
        Background="#F5EFE0">

    <Window.Resources>
        <!-- Style applied to every pit button on the board.
             Defined here (not in App.xaml) because:
               (a) it is only used inside this window, and
               (b) Window.Resources is reliably compiled to BAML in SDK-style
                   WPF projects, whereas Application.Resources can silently
                   skip BAML generation when StartupUri is removed.
             Uses a ControlTemplate so we get full control over the visual
             (rounded corners, hover/pressed/disabled effects) without losing
             the button's command/click behavior. -->
        <!-- Style for buttons that live inside the dark header bar.
             A flat dark-brown look that fits the header's color, with
             hover/pressed feedback. -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5B4032"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7A5A48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#7A5A48"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#4A3328"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PitButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="MinHeight" Value="70"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#3E2A1F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PART_Border"
                                Background="#E8C99B"
                                BorderBrush="#3E2A1F"
                                BorderThickness="2"
                                CornerRadius="40">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#F0D7B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#D4B280"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Border" Property="Background" Value="#D9D2C0"/>
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- The window is divided into 3 rows:
           Row 0: Header (title)
           Row 1: The board itself
           Row 2: Status bar -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER: title on the left, Setup + New Game buttons on the right.
             DockPanel with LastChildFill="False" lets each child claim
             only its own size so the title doesn't stretch across. -->
        <Border Grid.Row="0" Background="#3E2A1F" Padding="15,10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Mancala"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- Setup: re-opens the start-up dialog (difficulty + who starts). -->
                    <Button Content="Setup"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="OnSetupClick"
                            Margin="0,0,8,0"/>
                    <Button Content="New Game"
                            Style="{StaticResource HeaderButtonStyle}"
                            Command="{Binding NewGameCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- BOARD: [P2 Store] [Pits 2x6] [P1 Store] -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Player 2 Store (left side) -->
            <Border Grid.Column="0"
                    Width="100"
                    Background="#D9B383"
                    BorderBrush="#3E2A1F"
                    BorderThickness="2"
                    CornerRadius="50">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="P2"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="#3E2A1F"/>
                    <TextBlock Text="{Binding Store2}"
                               FontSize="40"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#3E2A1F"/>
                </StackPanel>
            </Border>

            <!-- Pits area: 2 rows x 6 columns -->
            <Grid Grid.Column="1" Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Player 2 pits (top row): board indices 12 to 7, left-to-right.
                     CommandParameter is the absolute board index passed to the engine. -->
                <Button Grid.Row="0" Grid.Column="0" Content="{Binding Pit12}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="12"/>
                <Button Grid.Row="0" Grid.Column="1" Content="{Binding Pit11}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="11"/>
                <Button Grid.Row="0" Grid.Column="2" Content="{Binding Pit10}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="10"/>
                <Button Grid.Row="0" Grid.Column="3" Content="{Binding Pit9}"  Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="9"/>
                <Button Grid.Row="0" Grid.Column="4" Content="{Binding Pit8}"  Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="8"/>
                <Button Grid.Row="0" Grid.Column="5" Content="{Binding Pit7}"  Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="7"/>

                <!-- Player 1 pits (bottom row): board indices 0 to 5, left-to-right. -->
                <Button Grid.Row="1" Grid.Column="0" Content="{Binding Pit0}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="0"/>
                <Button Grid.Row="1" Grid.Column="1" Content="{Binding Pit1}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="1"/>
                <Button Grid.Row="1" Grid.Column="2" Content="{Binding Pit2}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="2"/>
                <Button Grid.Row="1" Grid.Column="3" Content="{Binding Pit3}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="3"/>
                <Button Grid.Row="1" Grid.Column="4" Content="{Binding Pit4}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="4"/>
                <Button Grid.Row="1" Grid.Column="5" Content="{Binding Pit5}" Style="{StaticResource PitButtonStyle}"
                        Command="{Binding PlayPitCommand}" CommandParameter="5"/>
            </Grid>

            <!-- Player 1 Store (right side) -->
            <Border Grid.Column="2"
                    Width="100"
                    Background="#D9B383"
                    BorderBrush="#3E2A1F"
                    BorderThickness="2"
                    CornerRadius="50">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="P1"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="#3E2A1F"/>
                    <TextBlock Text="{Binding Store1}"
                               FontSize="40"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#3E2A1F"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#3E2A1F" Padding="15,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>
